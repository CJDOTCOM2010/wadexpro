# WADEXPRO — PRODUCTION DEPLOYMENT BLUEPRINT
# Use this as a template for your .env in the production environment.
# All values are mandatory for the hardened ecosystem.

# -----------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------
APP_NAME="WADEX PRO Logistics"
APP_ENV=production
APP_KEY=  # Generate using: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.wadexpro.com

# -----------------------------------------------------------------------
# Database — PostgreSQL Cluster
# -----------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=  # e.g., wadex-prod-db.cluster.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_DATABASE=wadex_logistics_prod
DB_USERNAME=  # Secure user with limited privileges
DB_PASSWORD=

# -----------------------------------------------------------------------
# Real-Time Engine — Node.js / Socket.IO
# -----------------------------------------------------------------------
SOCKET_URL=https://sockets.wadexpro.com
SOCKET_AUTH_KEY=  # Shared secret between Laravel and Node.js

# -----------------------------------------------------------------------
# Cache & Queues — Redis Persistence
# -----------------------------------------------------------------------
# Persistent Redis is MANDATORY for telemetry throttling and anti-fraud
REDIS_HOST=  # e.g., wadex-prod-redis.cache.amazonaws.com
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# -----------------------------------------------------------------------
# Resilience & Guard (WADEX-Guard)
# -----------------------------------------------------------------------
# Throttling: Enforced on SOS (3/5m) and Telemetry (12/1m)
THROTTLE_TELEMETRY=12
THROTTLE_SOS=3

# -----------------------------------------------------------------------
# Payments — Real Transactions
# -----------------------------------------------------------------------
PAYSTACK_PUBLIC_KEY=  # Get from Paystack Settings
PAYSTACK_SECRET_KEY=  # Get from Paystack Settings
PAYSTACK_PAYMENT_URL=https://api.paystack.co

# -----------------------------------------------------------------------
# Mobile App Configurations
# -----------------------------------------------------------------------
MOBILE_MIN_VERSION_DRIVER=1.0.0
MOBILE_MIN_VERSION_CUSTOMER=1.0.0

# -----------------------------------------------------------------------
# Maintenance
# -----------------------------------------------------------------------
# Prune old location data automatically every 3 days
PRUNE_TELEMETRY_DAYS=3
